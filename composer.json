{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "aws/aws-sdk-php": "*",
        "barryvdh/laravel-dompdf": "*",
        "beyondcode/laravel-websockets": "^1.14",
        "dedoc/scramble": "^0.11.16",
        "endroid/qr-code": "^5.0",
        "google/apiclient": "*",
        "guzzlehttp/guzzle": "^7.9",
        "innovination/chatgpt": "^1.0",
        "knplabs/knp-snappy": "*",
        "kreait/laravel-firebase": "^5.10",
        "laravel/framework": "^10.0",
        "laravel/pulse": "^1.2",
        "laravel/sanctum": "^3.3",
        "laravel/telescope": "^5.9",
        "laravel/tinker": "^2.8",
        "laravel/ui": "^4.2",
        "laraveldaily/laravel-charts": "^0.1.29",
        "league/flysystem-aws-s3-v3": "*",
        "nuovo/spreadsheet-reader": "^0.5.11",
        "pusher/pusher-php-server": "^7.2",
        "sentry/sentry-laravel": "^4.15",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "yajra/laravel-datatables-oracle": "^10.3"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.15",
        "fakerphp/faker": "^1.9.1",
        "friendsofphp/php-cs-fixer": "^3.75",
        "knuckleswtf/scribe": "^5.3",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "nunomaduro/larastan": "^2.10",
        "phpunit/phpunit": "^10.0",
        "spatie/laravel-ignition": "^2.0",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "lint": [
            "vendor/bin/phpcs --standard=PSR12 app/ routes/ tests/"
        ],
        "fix": [
            "vendor/bin/phpcbf --standard=PSR12 app/ routes/ tests/",
            "vendor/bin/php-cs-fixer fix"
        ],
        "analyze": [
            "vendor/bin/phpstan analyse --memory-limit=1G"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-master": "10.x-dev"
        },
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
